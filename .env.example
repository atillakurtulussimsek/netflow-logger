# NetFlow UDP dinleme adresi
NETFLOW_LISTEN_ADDRESS=:9995

# Kontrol paneli HTTP adresi
DASHBOARD_ADDRESS=:8080

# Kontrol paneli tek kullanıcı bilgileri
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=degistir-beni

# Log kök dizini
LOG_ROOT=./logs

# TSA servisi
TSA_URL=https://freetsa.org/tsr

# Uygulama zaman dilimi
TIMEZONE=Europe/Istanbul

# Zararlı IP kara listesi (/blocklist) erişim token'ı.
# OPNsense alias URL table: https://<host>:<port>/blocklist?token=<token>
# Boş bırakılırsa /blocklist endpoint'i tamamen devre dışı kalır (403).
BLOCKLIST_TOKEN=

# (Opsiyonel) /blocklist endpoint'ine yalnızca bu IP/CIDR'lardan erişime izin ver.
# Virgülle ayrılır, ör: 203.0.113.10,10.0.0.0/24. Boşsa IP kısıtı uygulanmaz.
BLOCKLIST_ALLOW_IPS=
